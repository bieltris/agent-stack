# Copy this file to .env and fill only the values you actually have.

# Required for OpenCode + NVIDIA
NVIDIA_API_KEY=nvapi-REPLACE_ME

# Host Ollama endpoint used by aider and local OpenCode fallback
OLLAMA_API_BASE=http://host.docker.internal:11434
OLLAMA_OPENCODE_BASE=http://host.docker.internal:11434/v1

# Optional workspace mount target for docker compose
WORKSPACE_DIR=..
